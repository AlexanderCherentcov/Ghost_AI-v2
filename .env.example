# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ghostline
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_random_64_char_string
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── OAUTH ────────────────────────────────────────────────────────────────────
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

TELEGRAM_BOT_TOKEN=

# ─── AI PROVIDERS (SECRET — never expose to frontend) ─────────────────────────
# OpenRouter — primary provider (chat, code, documents, image generation)
OPENROUTER_API_KEY=sk-or-v1-...
# Legacy direct keys (kept as fallback, not used by default)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...
REPLICATE_API_TOKEN=r8_...
RUNWAY_API_KEY=

# ─── YOKASSA ──────────────────────────────────────────────────────────────────
YOKASSA_SHOP_ID=
YOKASSA_SECRET_KEY=
YOKASSA_WEBHOOK_SECRET=

# ─── CLOUDFLARE R2 ────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ghostline-media
R2_PUBLIC_URL=https://media.ghostline.ai

# ─── BACKEND ──────────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
MINIAPP_URL=http://localhost:3001

# ─── FRONTEND (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_to_random_32_char_string

# ─── MONITORING ───────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
