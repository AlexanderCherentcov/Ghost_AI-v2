generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  BASIC
  PRO
  VIP
  ULTRA
}

enum Billing {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  CANCELED
  REFUNDED
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  birthDate     DateTime?
  email         String?   @unique
  telegramId    String?   @unique
  yandexId      String?   @unique
  googleId      String?   @unique
  avatarUrl     String?

  plan          Plan      @default(FREE)
  planExpiresAt DateTime?
  billing       Billing   @default(MONTHLY)

  // ── Caspers balance ───────────────────────────────────────────────────────
  caspers_balance  Int      @default(0)   // current spendable balance
  caspers_monthly  Int      @default(0)   // amount granted per billing period

  // ── Daily counters (reset at day_start + 1 day) ───────────────────────────
  std_messages_today  Int      @default(0)
  pro_messages_today  Int      @default(0)

  // ── FREE tier weekly counters (reset at week_start + 7 days) ─────────────
  images_this_week   Int      @default(0)
  music_this_week    Int      @default(0)
  // ── FREE tier monthly counter (reset at month_start + 30 days) ───────────
  videos_this_month  Int      @default(0)

  // ── Timestamps for period resets ─────────────────────────────────────────
  day_start    DateTime  @default(now())
  week_start   DateTime  @default(now())
  month_start  DateTime  @default(now())
  period_start DateTime  @default(now())

  // ── Onboarding ────────────────────────────────────────────────────────────
  purposes      String[]  @default([])
  responseStyle String    @default("ghost")
  onboardingDone Boolean  @default(false)

  // ── Relations ─────────────────────────────────────────────────────────────
  messages          Message[]
  chats             Chat[]
  payments          Payment[]
  imageRequests     UserImageRequest[]
  casperTransactions CasperTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([telegramId])
}

model Chat {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String    @default("Новый чат")
  mode      String    @default("chat")
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, updatedAt])
}

model Message {
  id         String   @id @default(cuid())
  chatId     String
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  role       String   // 'user' | 'assistant'
  content    String   @db.Text
  mode       String   // 'chat' | 'vision' | 'sound' | 'reel' | 'think'
  complexity String?
  provider   String?
  cacheHit   Boolean  @default(false)
  tokensCost Int      @default(0)
  mediaUrl   String?
  fileName   String?
  createdAt  DateTime @default(now())

  @@index([chatId, createdAt])
  @@index([userId, createdAt])
}

model Payment {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  yokassaId     String        @unique
  amount        Float
  status        PaymentStatus @default(PENDING)
  plan          Plan?
  paymentType   String        @default("subscription") // "subscription" | "caspers"
  casperAmount  Int?          // for casper top-up purchases
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId, createdAt])
}

model CasperTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Int      // positive = credit, negative = debit
  reason    String   // 'plan_grant' | 'topup' | 'chat_pro' | 'image' | 'video_std_4s' etc.
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model GenerateJob {
  id        String   @id @default(cuid())
  userId    String
  mode      String   // 'vision' | 'sound' | 'reel'
  status    String   @default("pending") // pending | processing | done | failed
  prompt    String   @db.Text
  mediaUrl  String?
  error     String?
  bullJobId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

model UserImageRequest {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  promptHash String
  createdAt  DateTime @default(now())

  @@unique([userId, promptHash])
  @@index([promptHash])
}
