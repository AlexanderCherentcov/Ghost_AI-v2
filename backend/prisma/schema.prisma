generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  BASIC
  STANDARD
  PRO
  ULTRA
  TEAM
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  CANCELED
  REFUNDED
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  birthDate     DateTime?
  email         String?   @unique
  telegramId    String?   @unique
  yandexId      String?   @unique
  googleId      String?   @unique
  avatarUrl     String?

  plan          Plan      @default(FREE)
  planExpiresAt DateTime?

  // ── Monthly counters (BASIC / STANDARD) ───────────────────────────────────
  messagesUsed  Int       @default(0)
  filesUsed     Int       @default(0)
  imagesUsed    Int       @default(0)
  videoUsed     Int       @default(0)   // reserved = 0

  // ── Daily counters (FREE / PRO / ULTRA) ───────────────────────────────────
  messagesToday Int       @default(0)
  dayStart      DateTime  @default(now())

  // ── Limits (copied from PLANS on subscribe) ───────────────────────────────
  // messagesLimit = -1 means "daily mode" (FREE/PRO/ULTRA)
  messagesLimit Int       @default(-1)  // FREE default: daily mode
  filesLimit    Int       @default(0)   // FREE default: no files
  imagesLimit   Int       @default(3)   // FREE default: 3/month
  videoLimit    Int       @default(0)   // reserved

  // ── Billing period ────────────────────────────────────────────────────────
  periodStart   DateTime  @default(now())

  // ── Onboarding ────────────────────────────────────────────────────────────
  purposes      String[]  @default([])
  responseStyle String    @default("ghost")
  onboardingDone Boolean  @default(false)

  // ── Relations ─────────────────────────────────────────────────────────────
  messages      Message[]
  chats         Chat[]
  payments      Payment[]
  imageRequests UserImageRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([telegramId])
}

model Chat {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String    @default("Новый чат")
  mode      String    @default("chat")
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, updatedAt])
}

model Message {
  id         String   @id @default(cuid())
  chatId     String
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  role       String   // 'user' | 'assistant'
  content    String   @db.Text
  mode       String   // 'chat' | 'vision' | 'sound' | 'reel' | 'think'
  complexity String?
  provider   String?
  cacheHit   Boolean  @default(false)
  tokensCost Int      @default(0)
  mediaUrl   String?
  fileName   String?
  createdAt  DateTime @default(now())

  @@index([chatId, createdAt])
  @@index([userId, createdAt])
}

model Payment {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  yokassaId     String        @unique
  amount        Float
  status        PaymentStatus @default(PENDING)
  plan          Plan?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId, createdAt])
}

model GenerateJob {
  id        String   @id @default(cuid())
  userId    String
  mode      String   // 'vision' | 'sound' | 'reel'
  status    String   @default("pending") // pending | processing | done | failed
  prompt    String   @db.Text
  mediaUrl  String?
  error     String?
  bullJobId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

model UserImageRequest {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  promptHash String
  createdAt  DateTime @default(now())

  @@unique([userId, promptHash])
  @@index([promptHash])
}
