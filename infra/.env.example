# ─── Database (existing postgres container in infra_ghost_net) ───────────────
DATABASE_URL=postgresql://ghost:PASSWORD@postgres:5432/ghostline_v2

# ─── Redis (existing redis container in infra_ghost_net) ─────────────────────
REDIS_URL=redis://:PASSWORD@redis:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── OAuth ────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
REPLICATE_API_TOKEN=
RUNWAY_API_KEY=

# ─── Payments (ЮKassa) ────────────────────────────────────────────────────────
YOKASSA_SHOP_ID=
YOKASSA_SECRET_KEY=
YOKASSA_WEBHOOK_SECRET=

# ─── Storage (Cloudflare R2 / S3) ─────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ghostline-media

# ─── CORS / URLs ──────────────────────────────────────────────────────────────
FRONTEND_URL=https://ghostlineai.ru
MINIAPP_URL=https://miniapp.ghostlineai.ru
PORT=4000
HOST=0.0.0.0
NODE_ENV=production
