# ══════════════════════════════════════════════════════════════════════════════
#  GhostLine AI — Environment Variables
#  Скопируй в .env и заполни. .env есть в .gitignore — никогда не коммить!
#
#  Быстрая генерация секретов:
#    openssl rand -hex 32   → для JWT_SECRET, ENCRYPTION_KEY
#    openssl rand -hex 24   → для POSTGRES_PASSWORD
#    openssl rand -hex 16   → для REDIS_PASSWORD, BOT_SECRET
# ══════════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=ghost
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=ghostline_v2
DATABASE_URL=postgresql://ghost:REPLACE_ME@postgres:5432/ghostline_v2

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_ME
REDIS_URL=redis://:REPLACE_ME@redis:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_ME
JWT_REFRESH_SECRET=REPLACE_ME
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Encryption (AES-256-GCM для сообщений в БД) ─────────────────────────────
ENCRYPTION_KEY=REPLACE_ME

# ─── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...

# ─── OAuth (Google / Yandex) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=https://api.ghostlineai.ru

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
BOT_SECRET=REPLACE_ME
FRONTEND_URL=https://ghostlineai.ru
MINIAPP_URL=https://miniapp.ghostlineai.ru

# ─── Frontend URLs (Next.js build-time) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.ghostlineai.ru
NEXT_PUBLIC_WS_URL=wss://api.ghostlineai.ru
NEXT_PUBLIC_SITE_URL=https://ghostlineai.ru
NEXT_PUBLIC_TG_BOT_USERNAME=GhostSuperAI_bot

# ─── Certbot / SSL ────────────────────────────────────────────────────────────
CERTBOT_EMAIL=admin@ghostlineai.ru
DOMAIN=ghostlineai.ru

# ─── Rate Limits ─────────────────────────────────────────────────────────────
CHAT_RPM=20
GEN_RPM=5
PORT=4000
NODE_ENV=production

# ─── Optional: Vector Cache (semantic) ───────────────────────────────────────
# EMBEDDING_API_KEY=sk-...   # OpenAI key (не Groq!)
# EMBEDDING_MODEL=text-embedding-3-small
# VECTOR_CACHE_THRESHOLD=0.95
